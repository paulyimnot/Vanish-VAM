KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Trading config
SYMBOL=BTC/USDT
ORDER_AMOUNT=0.001        # BTC per trade
RISK_PER_TRADE=0.01       # 1% of account per trade
ACCOUNT_BALANCE=5000      # USD — used for position sizing

# Strategy tuning
ATR_PERIOD=14             # bars (5-min each)
ATR_DORMANT_THRESHOLD=0.003   # 0.3% — skip if ATR below this
ATR_VOLATILE_THRESHOLD=0.02   # 2.0% — halve size if ATR above this
VOLUME_SPIKE_MULTIPLIER=2.0   # volume must be 2x avg to confirm
OBI_LONG_THRESHOLD=0.60       # order book imbalance for longs
OBI_SHORT_THRESHOLD=0.40      # order book imbalance for shorts
VWAP_BREAK_MIN=0.0015         # 0.15% minimum VWAP breakout distance
STOP_ATR_MULT=0.5             # stop = 0.5 x ATR from entry
TARGET_ATR_MULT=1.5           # target = 1.5 x ATR from entry (1:3 R:R)

# Safety
MAX_DAILY_LOSS=0.03       # halt if down 3%
MAX_DRAWDOWN=0.10         # halt if down 10% from peak
DRY_RUN=true              # MUST be false for live trading
