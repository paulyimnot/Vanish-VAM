KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Trading pair
SYMBOL=BTC/USDT

# Account & sizing
ACCOUNT_BALANCE=5000        # Your starting USD balance
RISK_PER_TRADE=0.01         # 1% of balance risked per trade (compound sizing)
MAX_DRAWDOWN_USD=500        # Circuit breaker: halt if down this many dollars

# Exchange fees (Kraken defaults)
MAKER_FEE=0.0016            # 0.16% — used for P&L simulation and breakeven calc

# Strategy R:R (1:3 default — profitable at 40% win rate)
STOP_ATR_MULT=0.5           # Stop = 0.5 × ATR from entry
TARGET_ATR_MULT=1.5         # Target = 1.5 × ATR from entry

# ATR / Regime settings
ATR_PERIOD=14               # Wilder ATR period (5-min bars)
ATR_DORMANT_THRESHOLD=0.003 # Skip if ATR < 0.3% of price (fees > edge)
ATR_VOLATILE_THRESHOLD=0.02 # Halve position if ATR > 2% (too risky)

# Signal quality filters
VOLUME_SPIKE_MULTIPLIER=2.0 # Volume must be 2× 20-bar average to confirm
OBI_LONG_THRESHOLD=0.60     # Order book imbalance for long entry
OBI_SHORT_THRESHOLD=0.40    # Order book imbalance for short entry
VWAP_BREAK_MIN=0.0015       # Price must break VWAP by 0.15% minimum

# Safety
MAX_DAILY_LOSS=0.03         # Halt if daily P&L drops 3% of account

# Set to false ONLY when ready for live trading
DRY_RUN=true
